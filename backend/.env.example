# SIPS HR Evaluation App — Environment Configuration
# Copy this file to .env and fill in real values for local development.
# In production (Render), values are set via the Render dashboard / render.yaml.

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Database
DB_PATH=./db/hr_eval.db

# App URL (used in invite + sign email links — must be reachable by the email recipient)
APP_URL=http://localhost:5173

# Invite token expiry (hours)
INVITE_EXPIRY_HOURS=48

# File uploads — disk path for QA + disciplinary attachments
UPLOAD_DIR=./uploads

# Email (SMTP)
# If SMTP_USER is blank, all emails are mocked to console (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=hr@sipsconsults.com
FROM_NAME=SIPS Healthcare HR
